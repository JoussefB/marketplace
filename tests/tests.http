@baseUrl = http://localhost:3000
@token =
@adminToken =
@skinId =
@userId =
@listingId =
@transactionId =

### Home
GET {{baseUrl}}/

########### AUTH

### 1. Register
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
    "username": "Joussef3",
    "email": "joussef3@student.vives.be",
    "password": "Azerty123"
}

### 2. Login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
    "email": "joussef3@student.vives.be",
    "password": "Azerty123"
}

########### SKINS

### 3. Get all skins
GET {{baseUrl}}/api/skins

### 4. Get skin by id
GET {{baseUrl}}/api/skins/{{skinId}}

### 5. Create skin - admin only
POST {{baseUrl}}/api/skins
Content-Type: application/json
x-auth-token: {{adminToken}}

{
    "name": "Glacier",
    "weaponType": "MP7",
    "rarity": "Epic",
    "releaseSeason": "Operation Black Ice"
}

### 6. Update skin - admin only
PUT {{baseUrl}}/api/skins/{{skinId}}
Content-Type: application/json
x-auth-token: {{adminToken}}

{
    "name": "Glacier Updated",
    "weaponType": "MP7",
    "rarity": "Legendary",
    "releaseSeason": "Operation Black Ice"
}

### 7. Delete skin - admin only
DELETE {{baseUrl}}/api/skins/{{skinId}}
x-auth-token: {{adminToken}}

### ObjectId validation check for skins
GET {{baseUrl}}/api/skins/not-a-valid-id

### Filter skins by rarity
GET {{baseUrl}}/api/skins/rarity/Epic

########### USERS

### 8. Get all users - admin only
GET {{baseUrl}}/api/users
x-auth-token: {{adminToken}}

### Get my profile
GET {{baseUrl}}/api/users/me
x-auth-token: {{token}}

### Get my inventory
GET {{baseUrl}}/api/users/me/inventory
x-auth-token: {{token}}

### 9. Get user by id - admin only
GET {{baseUrl}}/api/users/{{userId}}
x-auth-token: {{adminToken}}

### 10. Create user - admin only
POST {{baseUrl}}/api/users
Content-Type: application/json
x-auth-token: {{adminToken}}

{
    "username": "NieuweUser",
    "email": "nieuwe.user@student.vives.be",
    "password": "Azerty123",
    "credits": 120
}

### 11. Update user - admin only
PUT {{baseUrl}}/api/users/{{userId}}
Content-Type: application/json
x-auth-token: {{adminToken}}

{
    "username": "NieuweUserUpdated",
    "email": "nieuwe.user.updated@student.vives.be",
    "password": "Azerty123",
    "credits": 250
}

### 12. Delete user - admin only
DELETE {{baseUrl}}/api/users/{{userId}}
x-auth-token: {{adminToken}}

### ObjectId validation check for users
GET {{baseUrl}}/api/users/not-a-valid-id
x-auth-token: {{adminToken}}

########### LISTINGS

### 13. Get all active listings
GET {{baseUrl}}/api/listings

### 14. Get listing by id
GET {{baseUrl}}/api/listings/{{listingId}}

### Get my listings
GET {{baseUrl}}/api/listings/my-listings
x-auth-token: {{token}}

### Search listings
GET {{baseUrl}}/api/listings/search?maxPrice=500&rarity=Epic

### 15. Create listing - logged in user
POST {{baseUrl}}/api/listings
Content-Type: application/json
x-auth-token: {{token}}

{
    "price": 350,
    "skinData": {
        "name": "Glacier",
        "weaponType": "MP7",
        "rarity": "Epic",
        "releaseSeason": "Operation Black Ice"
    }
}

### 16. Buy listing - logged in user
POST {{baseUrl}}/api/listings/{{listingId}}/buy
x-auth-token: {{token}}

### 17. Update listing - seller or admin
PUT {{baseUrl}}/api/listings/{{listingId}}
Content-Type: application/json
x-auth-token: {{token}}

{
    "price": 400,
    "status": "active"
}

### 18. Delete listing - seller or admin
DELETE {{baseUrl}}/api/listings/{{listingId}}
x-auth-token: {{token}}

### ObjectId validation check for listings
GET {{baseUrl}}/api/listings/not-a-valid-id

########### TRANSACTIONS

### Get all transactions - admin only
GET {{baseUrl}}/api/transactions
x-auth-token: {{adminToken}}

### Get my transactions
GET {{baseUrl}}/api/transactions/my-transactions
x-auth-token: {{token}}

### Get transaction by id
GET {{baseUrl}}/api/transactions/{{transactionId}}
x-auth-token: {{token}}

### ObjectId validation check for transactions
GET {{baseUrl}}/api/transactions/not-a-valid-id
x-auth-token: {{token}}
